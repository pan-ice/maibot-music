{
  "manifest_version": 2,
  "id": "github.pan-ice.music",
  "version": "1.1.2",
  "name": "音乐插件",
  "description": "搜索点歌、解析音乐链接，发送语音音频，支持网易云音乐和QQ音乐",
  "author": {
    "name": "磐冰",
    "url": "https://github.com/pan-ice"
  },
  "license": "MIT",
  "urls": {
    "repository": "https://github.com/pan-ice/maibot-music",
    "issues": "https://github.com/pan-ice/maibot-music/issues"
  },
  "host_application": {
    "min_version": "1.0.0",
    "max_version": "1.99.99"
  },
  "sdk": {
    "min_version": "2.5.1",
    "max_version": "2.99.99"
  },
  "dependencies": [
    {
      "type": "python_package",
      "name": "httpx",
      "version_spec": ">=0.27.0"
    },
    {
      "type": "python_package",
      "name": "cryptography",
      "version_spec": ">=42.0.0"
    }
  ],
  "capabilities": [
    "send.text",
    "send.custom"
  ],
  "i18n": {
    "default_locale": "zh-CN",
    "supported_locales": [
      "zh-CN"
    ]
  }
}
